#!/usr/bin/env php
<?php

chdir(__DIR__ . '/..');

echo "# Running composer install for platform\n\n";
composer_install('src/plugins/content/commonmark');

function composer_install($folder)
{
    chdir($folder);

    system('composer install --no-dev --no-progress --ignore-platform-reqs', $composerReturnCode);

    if ($composerReturnCode !== 0) {
        echo "`composer install` did not complete as expected in $folder.\n";
        exit(1);
    }

    chdir(preg_replace('|[^/]+|', '..', $folder));
}
